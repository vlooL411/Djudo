<Page x:Class="Djudo.MainCtrl"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:Djudo"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="MainCtrl">

	<Viewbox>
		<Grid>
			<Grid.RowDefinitions>
				<RowDefinition Height="1*"/>
				<RowDefinition Height="1*"/>
			</Grid.RowDefinitions>
			<Grid.ColumnDefinitions>
				<ColumnDefinition Width="1*"/>
				<ColumnDefinition Width="1*"/>
				<ColumnDefinition Width="1*"/>
			</Grid.ColumnDefinitions>
			<Button Click="Uch_Click" Margin="10 15" Content="Участники" Background="Red" BorderBrush="#FFD6EA91"/>
			<Button Click="GU_Click" Grid.Column="1" Margin="10 15" Content="Группа участников" Background="#FF00FF17" BorderBrush="#FFD6EA91"/>
			<Button Click="Tat_Click" Grid.Column="2" Margin="10 15" Content="Татами" Background="#FF00B9FF" BorderBrush="#FFD6EA91"/>
			
			<Button Click="WindowCtrl_Click" Grid.ColumnSpan="3" Margin="10 15" Grid.Row="1" Content="Окно управления" Background="#FFDD14F1" BorderBrush="#FFD6EA91"/>
		</Grid>
	</Viewbox>
</Page>
