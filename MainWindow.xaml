<Window x:Class="Djudo.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Djudo"
        mc:Ignorable="d"
		WindowStartupLocation="CenterScreen"
        Title="MainWindow" MinHeight="550" Height="550" Width="900" MinWidth="900">
	<Grid>
		<Grid.RowDefinitions>
			<RowDefinition Height="0.6*" MaxHeight="30"/>
			<RowDefinition Height="9*"/>
		</Grid.RowDefinitions>
		<Viewbox Margin="5 0 0 0" HorizontalAlignment="Left">
			<Button Content="Back" Click="Back_Click" Padding="10 5" Background="#FF8BDC66" BorderBrush="#FFF0CFCF"/>
		</Viewbox>
		<Viewbox Margin="0 0 5 0" HorizontalAlignment="Right">
			<Button Content="Exit" Padding="10 5" Click="Button_Click" Background="#FF9CD5F5" BorderBrush="#FFF0CFCF"/>
		</Viewbox>
		<Grid x:Name="gr" Grid.Row="1">
		</Grid>
	</Grid>
</Window>
